{
  "name": "ferreteria-chavalos-web",
  "version": "1.5.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "prebuild": "npm run prisma:generate",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "schema:sync": "node scripts/sync-schema.mjs",
    "prisma:generate": "npm run schema:sync && prisma generate --schema=prisma/schema.prisma",
    "prisma:studio": "npm run schema:sync && prisma studio --schema=prisma/schema.prisma",
    "db:migrate": "npm run schema:sync && prisma migrate dev --schema=prisma/schema.prisma",
    "db:seed": "npm run prisma:generate && tsx scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "bcrypt": "^6.0.0",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lru-cache": "^11.2.6",
    "next": "^15.5.9",
    "next-auth": "^5.0.0-beta.30",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "swr": "^2.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "prisma": "6.19.2",
    "qrcode": "^1.5.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "tar": "^7.5.3"
  },
  "optionalDependencies": {
    "@next/swc-win32-x64-msvc": "15.5.9"
  }
}
