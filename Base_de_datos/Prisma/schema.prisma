// Prisma Schema - Ferretería Chavalos
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========== ENUMS ==========
enum UserRole {
  ADMIN
  CAJERO
}

enum ProductUnit {
  UNIDAD
  METRO
  LITRO
  KILO
  CAJA
  PAQUETE
  ROLLO
}

enum StockMovementType {
  ENTRADA
  SALIDA
  AJUSTE
}

enum PaymentMethod {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
}

enum CustomerDocType {
  DNI
  RUC
  PASAPORTE
  OTRO
}


// ========== MODELS ==========
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(CAJERO)
  fullName     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sales        Sale[]
  priceChanges PriceChange[]

  @@map("users")
}

model Product {
  id          String      @id @default(cuid())
  sku         String      @unique
  name        String
  description String?
  unit        ProductUnit @default(UNIDAD)
  price       Decimal     @db.Decimal(12, 2)
  stock       Decimal     @db.Decimal(12, 3) @default(0)
  minStock    Decimal     @db.Decimal(12, 3) @default(5)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  presentations  ProductPresentation[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]
  priceChanges   PriceChange[]

  @@index([sku])
  @@index([name])
  @@map("products")
}

model Sale {
  id              String        @id @default(cuid())
  saleNumber      String        @unique
  userId          String
  customerName    String?
  paymentMethod   PaymentMethod @default(EFECTIVO)
  subtotal        Decimal       @db.Decimal(12, 2)
  tax             Decimal       @db.Decimal(12, 2) @default(0)
  total           Decimal       @db.Decimal(12, 2)
  stockOverride   Boolean       @default(false)
  overrideNote    String?
  createdAt       DateTime      @default(now())
  customerDocType    CustomerDocType?
  customerDocNumber  String?
  customerAddress    String?
  institutionName    String?
  observations       String?
  updatedAt          DateTime    @updatedAt

  user  User       @relation(fields: [userId], references: [id])
  items SaleItem[]

  @@index([saleNumber])
  @@index([userId])
  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id              String   @id @default(cuid())
  saleId          String
  productId       String
  presentationId  String?
  soldUnit        ProductUnit
  soldQty         Decimal  @db.Decimal(12, 3)
  baseQty         Decimal  @db.Decimal(12, 3)
  unitPrice         Decimal   @db.Decimal(12, 2)
  unitPriceOverride Decimal?  @db.Decimal(12, 2)
  priceAdjustNote   String?
  subtotal          Decimal   @db.Decimal(12, 2)
  createdAt         DateTime  @default(now())

  sale          Sale                  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product       Product               @relation(fields: [productId], references: [id])
  presentation  ProductPresentation?  @relation(fields: [presentationId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model StockMovement {
  id            String            @id @default(cuid())
  productId     String
  type          StockMovementType
  quantity      Decimal           @db.Decimal(12, 3)
  reference     String?
  notes         String?
  previousStock Decimal           @db.Decimal(12, 3)
  newStock      Decimal           @db.Decimal(12, 3)
  createdAt     DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}

model ProductPresentation {
  id            String      @id @default(cuid())
  productId     String
  name          String
  unit          ProductUnit
  factorToBase  Decimal     @db.Decimal(12, 3) @default(1)
  priceOverride Decimal?    @db.Decimal(12, 2)
  isDefault     Boolean     @default(false)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  saleItems     SaleItem[]
  priceChanges  PriceChange[]

  @@unique([productId, name])
  @@index([productId])
  @@map("product_presentations")
}

model PriceChange {
  id              String      @id @default(cuid())
  productId       String
  presentationId  String?
  oldPrice        Decimal     @db.Decimal(12, 2)
  newPrice        Decimal     @db.Decimal(12, 2)
  reason          String
  userId          String
  createdAt       DateTime    @default(now())

  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  presentation    ProductPresentation? @relation(fields: [presentationId], references: [id], onDelete: SetNull)
  user            User        @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([createdAt])
  @@map("price_changes")
}

