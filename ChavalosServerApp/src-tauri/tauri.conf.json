{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chavalos Server",
  "version": "1.0.0",
  "identifier": "com.chavalos.admin",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Chavalos Server",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/node"],
    "resources": [
      "resources/**/*",
      "resources/**/.*"
    ],
    "copyright": "Copyright © 2026 Ferretería Chavalos",
    "category": "DeveloperTool",
    "shortDescription": "Servidor de gestión Ferretería Chavalos",
    "longDescription": "Aplicación para gestionar el servidor web de la Ferretería Chavalos",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "es-ES"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
